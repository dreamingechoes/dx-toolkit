{
  "name": "dx-toolkit",
  "version": "1.0.0",
  "private": true,
  "description": "DX toolkit — AI-powered agents, workflows, prompts, instructions, skills, hooks, and templates",
  "scripts": {
    "format": "prettier --write '**/*.{md,yml,yaml,json,css,scss}'",
    "format:check": "prettier --check '**/*.{md,yml,yaml,json,css,scss}'",
    "format:md": "prettier --write '**/*.md'",
    "format:yml": "prettier --write '**/*.{yml,yaml}'",
    "format:json": "prettier --write '**/*.json'"
  },
  "devDependencies": {
    "prettier": "^3.5.3"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dreamingechoes/dx-toolkit.git"
  }
}
